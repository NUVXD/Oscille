{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Wall",
                "/external:W0",
                "/wd5045",
                "/GS-",
                
                "${workspaceFolder}${/}src${/}*.c",
                
                "/I${workspaceFolder}${/}include",
                "/external:I${workspaceFolder}${/}external${/}SDL3${/}include${/}",

                "/Fo${workspaceFolder}${/}build${/}",
                "/Fe${workspaceFolder}${/}build${/}Oscille.exe",
                
                "/link",
                "/LIBPATH:${workspaceFolder}${/}external${/}SDL3${/}lib${/}x64",
                "SDL3.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}